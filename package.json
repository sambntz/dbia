{
  "name": "dbia",
  "version": "1.0.0",
  "description": "Database Introspection Assistant",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dbia": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli/index.js",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "database",
    "introspection",
    "cli",
    "mysql",
    "postgres",
    "sqlite"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "mysql2": "^3.10.0",
    "pg": "^8.12.0",
    "picocolors": "^1.0.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
