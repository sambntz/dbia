# DBIA Master Key (optional but recommended)
# If not set, DBIA will generate a master key and store it in ~/.dbia/master.key
# If you change this variable, existing passwords cannot be decrypted.
# DBIA_MASTER_KEY=a-very-secure-key-of-at-least-32-characters

# Custom directory for DBIA data (optional)
# Default: ~/.dbia
# DBIA_DATA_DIR=/custom/path/dbia
